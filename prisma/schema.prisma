// Cobblemon Shop - Prisma Schema
// Production-ready relational schema for Minecraft Cobblemon webshop

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum ProductType {
  RANK
  SUBSCRIPTION
  CURRENCY
  COSMETIC
  CRATE_KEY
  BUNDLE
  PERK
  BATTLE_PASS
  LIMITED_OFFER
  FREE_REWARD
}

enum ProductVisibility {
  PUBLIC
  HIDDEN
  DRAFT
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  QUEUED_DELIVERY
  DELIVERED
  PARTIALLY_DELIVERED
  FAILED_DELIVERY
  REFUNDED
  CANCELED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DeliveryItemStatus {
  PENDING
  QUEUED
  DELIVERED
  FAILED
}

enum DeliveryJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  SKIPPED
}

enum AnnouncementType {
  INFO
  WARNING
  SALE
  EVENT
  MAINTENANCE
}

enum HomepageSectionType {
  HERO
  FEATURED
  CATEGORY
  BANNER
  TEXT
  PRODUCTS
}

enum DeliveryMode {
  DRY_RUN
  WEBHOOK
  RCON
}

enum WikiArticleStatus {
  DRAFT
  PUBLISHED
  OUTDATED
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id            String            @id @default(cuid())
  email         String            @unique @db.VarChar(255)
  username      String            @unique @db.VarChar(100)
  passwordHash  String            @db.Text
  displayName   String?           @db.VarChar(255)
  avatarUrl     String?           @db.Text
  emailVerified DateTime?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relations
  minecraftAccount MinecraftAccount?
  roles            UserRole[]
  orders           Order[]
  cartItems        CartItem[]
  auditLogs        AuditLog[]

  @@index([email])
  @@index([username])
  @@index([createdAt])
  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique @db.VarChar(100)
  description String?          @db.Text
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())

  // Relations
  permissions RolePermission[]
  users       UserRole[]

  @@index([name])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique @db.VarChar(100)
  description String?          @db.Text
  group       String           @db.VarChar(100)

  // Relations
  roles RolePermission[]

  @@index([code])
  @@index([group])
  @@map("permissions")
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model MinecraftAccount {
  id         String    @id @default(cuid())
  userId     String    @unique
  username   String    @unique @db.VarChar(16)
  uuid       String    @unique @db.VarChar(36)
  verifiedAt DateTime?
  linkedAt   DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([username])
  @@index([uuid])
  @@map("minecraft_accounts")
}

// ============================================================================
// PRODUCTS & CATALOG
// ============================================================================

model Category {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  imageUrl    String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  parent           Category?        @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children         Category[]       @relation("CategoryHierarchy")
  products         Product[]
  couponCategories CouponCategory[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Product {
  id                 String            @id @default(cuid())
  name               String            @db.VarChar(255)
  slug               String            @unique @db.VarChar(255)
  shortDescription   String?           @db.VarChar(500)
  fullDescription    String?           @db.Text
  imageUrl           String?           @db.Text
  bannerUrl          String?           @db.Text
  categoryId         String
  price              Decimal           @db.Decimal(10, 2)
  compareAtPrice     Decimal?          @db.Decimal(10, 2)
  productType        ProductType
  isFeatured         Boolean           @default(false)
  isActive           Boolean           @default(true)
  visibility         ProductVisibility @default(DRAFT)
  stockLimit         Int?
  stockSold          Int               @default(0)
  purchaseLimit      Int?
  cooldownMinutes    Int?
  startDate          DateTime?
  endDate            DateTime?
  deliveryTemplateId String?
  metadata           Json?
  sortOrder          Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // Relations
  category         Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems       OrderItem[]
  bundleItems      BundleItem[]      @relation("BundleProduct")
  bundledIn        BundleItem[]      @relation("BundledProduct")
  tags             ProductTag[]
  deliveryTemplate DeliveryTemplate? @relation(fields: [deliveryTemplateId], references: [id], onDelete: SetNull)
  cartItems        CartItem[]
  couponProducts   CouponProduct[]

  @@index([slug])
  @@index([categoryId])
  @@index([productType])
  @@index([isActive])
  @@index([visibility])
  @@index([isFeatured])
  @@index([createdAt])
  @@map("products")
}

model ProductTag {
  id        String  @id @default(cuid())
  productId String
  tag       String  @db.VarChar(100)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, tag])
  @@index([tag])
  @@map("product_tags")
}

model BundleItem {
  id       String  @id @default(cuid())
  bundleId String
  itemId   String
  quantity Int     @default(1)
  bundle   Product @relation("BundleProduct", fields: [bundleId], references: [id], onDelete: Cascade)
  item     Product @relation("BundledProduct", fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([bundleId, itemId])
  @@index([bundleId])
  @@index([itemId])
  @@map("bundle_items")
}

model DeliveryTemplate {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  commandTemplate String   @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  products     Product[]
  deliveryJobs DeliveryJob[]

  @@index([name])
  @@map("delivery_templates")
}

// ============================================================================
// COMMERCE - CART & ORDERS
// ============================================================================

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("cart_items")
}

model Coupon {
  id               String       @id @default(cuid())
  code             String       @unique @db.VarChar(50)
  description      String?      @db.Text
  discountType     DiscountType
  discountValue    Decimal      @db.Decimal(10, 2)
  maxUses          Int?
  usedCount        Int          @default(0)
  perUserLimit     Int          @default(1)
  minCartValue     Decimal?     @db.Decimal(10, 2)
  startDate        DateTime?
  endDate          DateTime?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  applicableProducts   CouponProduct[]
  applicableCategories CouponCategory[]
  orders               Order[]

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model CouponProduct {
  couponId  String
  productId String
  coupon    Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([couponId, productId])
  @@index([couponId])
  @@index([productId])
  @@map("coupon_products")
}

model CouponCategory {
  couponId   String
  categoryId String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([couponId, categoryId])
  @@index([couponId])
  @@index([categoryId])
  @@map("coupon_categories")
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique @db.VarChar(50)
  userId      String
  status      OrderStatus @default(PENDING_PAYMENT)
  subtotal    Decimal     @db.Decimal(10, 2)
  discount    Decimal     @default(0) @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)
  couponId    String?
  couponCode  String?     @db.VarChar(50)
  playerName  String?     @db.VarChar(16)
  playerUuid  String?     @db.VarChar(36)
  notes       String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  user         User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  items        OrderItem[]
  payments     PaymentTransaction[]
  deliveryJobs DeliveryJob[]
  coupon       Coupon?              @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id             String             @id @default(cuid())
  orderId        String
  productId      String?
  productName    String             @db.VarChar(255)
  productType    ProductType
  quantity       Int
  unitPrice      Decimal            @db.Decimal(10, 2)
  totalPrice     Decimal            @db.Decimal(10, 2)
  deliveryStatus DeliveryItemStatus @default(PENDING)
  deliveredAt    DateTime?
  order          Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  deliveryJobs   DeliveryJob[]

  @@index([orderId])
  @@index([productId])
  @@index([deliveryStatus])
  @@map("order_items")
}

model PaymentTransaction {
  id                    String        @id @default(cuid())
  orderId               String
  provider              String        @db.VarChar(100)
  providerTransactionId String?       @db.VarChar(255)
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("USD") @db.VarChar(3)
  status                PaymentStatus @default(PENDING)
  checkoutUrl           String?       @db.Text
  rawResponse           Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  order                 Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([provider])
  @@index([status])
  @@index([providerTransactionId])
  @@map("payment_transactions")
}

// ============================================================================
// DELIVERY SYSTEM
// ============================================================================

model DeliveryJob {
  id              String            @id @default(cuid())
  orderId         String
  orderItemId     String
  idempotencyKey  String            @unique @db.VarChar(255)
  templateId      String?
  renderedCommand String            @db.Text
  status          DeliveryJobStatus @default(PENDING)
  attempts        Int               @default(0)
  maxAttempts     Int               @default(3)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?
  response        String?           @db.Text
  error           String?           @db.Text
  isDryRun        Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem         @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  template  DeliveryTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  logs      DeliveryLog[]

  @@index([orderId])
  @@index([orderItemId])
  @@index([status])
  @@index([idempotencyKey])
  @@index([nextRetryAt])
  @@map("delivery_jobs")
}

model DeliveryLog {
  id         String            @id @default(cuid())
  jobId      String
  attempt    Int
  status     DeliveryJobStatus
  command    String            @db.Text
  response   String?           @db.Text
  error      String?           @db.Text
  executedAt DateTime          @default(now())
  job        DeliveryJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([executedAt])
  @@map("delivery_logs")
}

// ============================================================================
// CONTENT & SITE MANAGEMENT
// ============================================================================

model Announcement {
  id        String           @id @default(cuid())
  title     String           @db.VarChar(255)
  content   String           @db.Text
  type      AnnouncementType
  isActive  Boolean          @default(true)
  startDate DateTime?
  endDate   DateTime?
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())

  @@index([isActive])
  @@index([type])
  @@index([createdAt])
  @@map("announcements")
}

model HomepageSection {
  id        String              @id @default(cuid())
  title     String              @db.VarChar(255)
  subtitle  String?             @db.VarChar(500)
  type      HomepageSectionType
  content   Json?
  imageUrl  String?             @db.Text
  linkUrl   String?             @db.Text
  isActive  Boolean             @default(true)
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([isActive])
  @@index([sortOrder])
  @@map("homepage_sections")
}

model SupportArticle {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  content     String   @db.Text
  category    String   @db.VarChar(100)
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([isPublished])
  @@map("support_articles")
}

model WikiCategory {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  icon        String?  @db.VarChar(100)
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  articles WikiArticle[]

  @@index([slug])
  @@index([sortOrder])
  @@index([isVisible])
  @@map("wiki_categories")
}

model WikiArticle {
  id             String            @id @default(cuid())
  title          String            @db.VarChar(255)
  slug           String            @unique @db.VarChar(255)
  excerpt        String            @db.VarChar(500)
  content        String            @db.LongText
  coverImage     String?           @db.Text
  categoryId     String
  isPublished    Boolean           @default(false)
  isFeatured     Boolean           @default(false)
  sortOrder      Int               @default(0)
  seoTitle       String?           @db.VarChar(255)
  seoDescription String?           @db.VarChar(500)
  gameVersion    String?           @db.VarChar(100)
  status         WikiArticleStatus @default(DRAFT)
  lastReviewedAt DateTime?
  searchKeywords String?           @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Relations
  category WikiCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([slug])
  @@index([categoryId])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([status])
  @@index([sortOrder])
  @@index([updatedAt])
  @@index([categoryId, isPublished])
  @@index([isPublished, isFeatured])
  @@map("wiki_articles")
}

model SeasonalCampaign {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  imageUrl    String?  @db.Text
  bannerUrl   String?  @db.Text
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([startDate])
  @@map("seasonal_campaigns")
}

// ============================================================================
// AUDIT & LOGGING
// ============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?  @db.VarChar(255)
  action    String   @db.VarChar(255)
  target    String   @db.VarChar(100)
  targetId  String?  @db.VarChar(255)
  details   Json?
  ipAddress String?  @db.VarChar(45)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([target])
  @@index([createdAt])
  @@map("audit_logs")
}
